{
  "name": "moonstone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:index": "node scripts/generate-passive-context-index.mjs --write",
    "refresh:cognitive-map": "npm run docs:index",
    "spec:scaffold": "node scripts/spec-scaffold.mjs",
    "spec:lint": "node scripts/spec-lint.mjs",
    "spec:validate": "node scripts/spec-validate.mjs",
    "check:skills": "node scripts/check-skills.mjs",
    "check:spec": "node scripts/check-spec.mjs",
    "check:strategy": "node scripts/check-strategy-trackers.mjs",
    "check:epistemic-gaps": "node scripts/check-epistemic-gaps.mjs",
    "check:skill-prereqs": "node scripts/check-skill-prereqs.mjs",
    "check:parity": "node scripts/check-parity.mjs",
    "check:branch-name": "node scripts/check-branch-name.mjs",
    "check:pr-title": "node scripts/check-pr-title.mjs",
    "check:pr-governance": "node scripts/check-pr-governance.mjs",
    "check:scope-classifier": "node scripts/test-verification-scope-classifier.mjs",
    "check:prepush-fast": "node scripts/check-prepush-fast.mjs",
    "check:links": "node scripts/check-doc-links.mjs",
    "check:symlinks": "node scripts/check-no-external-doc-symlinks.mjs",
    "check:memory": "node scripts/check-memory-gitignore.mjs",
    "check:workspace-safety": "node scripts/check-workspace-safety-policy.mjs",
    "check:session-automation": "node scripts/check-session-automation-policy.mjs",
    "check:text-hygiene": "node scripts/check-text-hygiene.mjs",
    "check:verification-fresh": "node scripts/check-verification-fresh.mjs",
    "state:recall": "node scripts/session-state.mjs recall",
    "state:set": "node scripts/session-state.mjs set",
    "state:verification": "node scripts/session-state.mjs verification",
    "poc:compile": "node scripts/poc-compile.mjs",
    "poc:validate": "node scripts/poc-validate.mjs",
    "poc:mutate": "node scripts/poc-mutate.mjs",
    "poc:run": "node scripts/poc-run.mjs",
    "poc:resume": "node scripts/poc-resume.mjs",
    "poc:serve": "node scripts/poc-serve.mjs",
    "poc:replay": "node scripts/poc-replay.mjs",
    "poc:inspect": "node scripts/poc-inspect.mjs",
    "poc:pilot": "node scripts/poc-pilot.mjs",
    "poc:qualify:demo": "node --test test/integration/conformance/poc-demo-runbook-qualification.conformance.test.mjs",
    "poc:qualify:pilot": "node --test test/integration/conformance/poc-pilot-01-qualification.conformance.test.mjs",
    "poc:qualify:resume": "node --test test/integration/conformance/poc-resume-cli-qualification.conformance.test.mjs",
    "poc:qualify:webhook": "node --test test/integration/conformance/poc-webhook-e2e-qualification.conformance.test.mjs",
    "check:type": "tsc --noEmit -p tsconfig.json",
    "check:lint": "node scripts/check-lint.mjs",
    "lint:fix": "node scripts/lint-fix.mjs",
    "check:contracts": "node scripts/check-typecheck.mjs",
    "check:index": "node scripts/check-passive-index-freshness.mjs",
    "test:unit": "node --test \"test/unit/**/*.test.mjs\" \"test/model/**/*.test.mjs\"",
    "conformance:lint": "node scripts/conformance-lint.mjs",
    "test:conformance": "node scripts/run-conformance.mjs",
    "verify:core": "npm run docs:index && npm run check:skills && npm run check:spec && npm run check:strategy && npm run check:epistemic-gaps && npm run check:links && npm run check:symlinks && npm run check:memory && npm run check:workspace-safety && npm run check:session-automation && npm run check:text-hygiene && npm run check:type && npm run check:lint && npm run check:contracts && npm run test:unit",
    "verify": "node scripts/run-with-state.mjs -- npm run verify:core",
    "verify:strict:core": "npm run verify:core && npm run check:parity && npm run check:index && npm run check:scope-classifier && npm run check:branch-name && npm run check:strategy && npm run test:conformance",
    "verify:strict": "node scripts/run-with-state.mjs -- npm run verify:strict:core"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "typescript": "^5.9.3"
  }
}
