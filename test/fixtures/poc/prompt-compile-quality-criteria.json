{
  "version": "1.0.0",
  "minimumFixtureCount": 6,
  "determinism": {
    "runsPerFixture": 2
  },
  "requiredBranchModes": ["default", "exists", "comparator"],
  "requiredScenarioIds": [
    "default-linear",
    "exists-branch",
    "comparator-branch",
    "comparator-equals-branch",
    "failure-branch",
