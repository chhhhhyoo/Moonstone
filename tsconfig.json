{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": [
      "node"
    ]
  },
  "include": [
    "src/core/AgentIntent.mjs",
    "src/core/ConversationContext.mjs",
    "src/core/KernelEnvelope.mjs",
    "src/core/OperationReceipt.mjs",
    "src/core/SessionKey.mjs",
    "src/core/contracts.mjs"
  ],
  "exclude": [
    "node_modules"
  ]
}
